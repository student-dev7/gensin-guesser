# Firebase（クライアント用・NEXT_PUBLIC はブラウザに埋め込まれる）
# コンソール: プロジェクト設定 → マイアプリ → SDK の設定
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Firebase Analytics / Google アナリティクス（コンソールの Web アプリ設定の measurementId、例: G-xxxxxxxxxx）
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
# デバッグ UI（DBG・正解表示）を本番で使う UID（カンマ区切り・任意。コード内 BUILTIN と併用）
# NEXT_PUBLIC_ADMIN_UIDS=
# 管理者モードのパスワード（サーバー専用・NEXT_PUBLIC は付けない）。/api/verify-admin で検証
# ローカル: .env.local に ADMIN_PANEL_PASSWORD=... を書く（.gitignore 済み）
# Vercel: プロジェクト → Settings → Environment Variables で同名を追加し、
#         Production（必要なら Preview も）にチェック → Save 後「Redeploy」を実行
ADMIN_PANEL_PASSWORD=

# 管理者のみ: 全ユーザーのシーズンレート一括更新・個別上書き
# （/api/admin/mass-down-season-rating・mass-down-500・set-user-season-rating・mass-reset-all-season-rating）
# Firebase コンソール → プロジェクト設定 → サービスアカウント → 新しい鍵の生成
# 本番（Vercel 等）: JSON 全文を 1 行で
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# ローカル: 鍵ファイルパスでも可（scripts/mass-down-season-rating.mjs も参照）
# FIREBASE_SERVICE_ACCOUNT_KEY_PATH=./secrets/firebase-adminsdk.json

# ランキングは `users.leaderboard_rating` で並べ替え（読み取りは上位 N 件のみ）。
# 既存 DB は一度 `npm run backfill:leaderboard-rating`（要 FIREBASE_SERVICE_ACCOUNT_JSON）で埋める。

# Vercel Cron: /api/cron/cleanup-stale-rooms の認証（Authorization: Bearer ...）
# 本番では未設定だと掃除 API が 401 のまま（ルームが消えない原因になる）
# CRON_SECRET=
# 任意: 放置ルーム削除のしきい値（ミリ秒。未設定時は 7 日）
# ROOM_STALE_AFTER_MS=
# 任意: 試合未開始のまま lastActivityAt がこの時間より古いルームを削除（ミリ秒。未設定時は 7 分＝420000）
# Vercel Hobby はダッシュボードの Cron が 1 日 1 回に制限されがち。短い間隔で掃除するには
# `.github/workflows/cleanup-stale-rooms.yml` で同じ API を叩く（要 GitHub の secrets）か Pro を検討。
# ROOM_LOBBY_NO_MATCH_MS=
