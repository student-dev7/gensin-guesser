// =============================================================================
// 【緊急遮断用】Safety Lock — Firebase コンソールの Rules にそのまま貼り替え
// 全クライアントの Firestore 読み書きを拒否（ゲーム・ルーム・チャット・ランキング表示等が止まる）
// 復旧時は firestore.rules（通常版）の内容に戻す
// =============================================================================
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
